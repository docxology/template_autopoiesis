# template_autopoiesis root gitignore — inherits parent repo's rules.
# Local caches that should not be tracked. output/ IS tracked (like every
# other public exemplar) — it is this project's reproducibility bundle.
__pycache__/
*.pyc
.pytest_cache/
.coverage
htmlcov/
benchmarks/
.hypothesis/
.mypy_cache/
.ruff_cache/